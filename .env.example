# The Byline — Production Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env, fill in real values, then run:
#   docker compose up -d
#
# NEVER commit .env to git. .env is already in .gitignore.

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://yourdomain.com

# Generate with: openssl rand -base64 48
REMEMBER_ME_KEY=<generate-with-openssl-rand-base64-48>

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=thebyline
DB_USER=thebyline
# Generate with: openssl rand -base64 32
DB_PASS=<strong-random-password>

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# Uncomment and set if your Redis requires authentication:
# REDIS_PASS=<redis-auth-password>

# ── AI (optional — required for AI features) ──────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── File Storage (AWS S3 or S3-compatible) ────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=thebyline-media
# For S3-compatible storage (MinIO, R2, etc.), set the endpoint:
# S3_ENDPOINT=https://your-s3-endpoint.com
# CDN_URL=https://cdn.yourdomain.com

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
# Use live keys in production; test keys for staging
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....

# ── Newsletter ────────────────────────────────────────────────────────────────
BUTTONDOWN_API_KEY=

# ── Analytics ─────────────────────────────────────────────────────────────────
PLAUSIBLE_DOMAIN=yourdomain.com
# PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js
